# DroneRL Environment Variables — example
# Copy this file to .env and edit values, OR export them in your shell.
# Every variable below is read at runtime by the source code; nothing
# documented here is purely cosmetic.

# Multi-seed / sweep parallelism (analysis/_runner.py:resolve_workers).
# Default 1 (serial). Set to a positive integer N to spawn an
# N-worker multiprocessing.Pool for the sweep scripts. Hard ceiling
# is min(this, config.analysis.max_parallel_workers, os.cpu_count()).
DRONERL_PARALLEL=1

# Pygame video driver. The headless capture scripts
# (scripts/capture_*.py) set this internally to `dummy` so they can
# run in CI / on a display-less server. You normally do NOT set this
# yourself — the GUI needs the OS default to render.
# SDL_VIDEODRIVER=dummy
